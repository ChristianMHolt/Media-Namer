<Application xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="MediaNamer.App"
             RequestedThemeVariant="Dark"> <Application.Styles>
        <FluentTheme>
            <FluentTheme.Palettes>
                <ColorPaletteResources x:Key="Dark" 
                                       Accent="#4169E1" 
                                       RegionColor="#2b2b2b" 
                                       BaseHigh="White" />
            </FluentTheme.Palettes>
        </FluentTheme>
    </Application.Styles>
</Application>